{
  "name": "lucky3",
  "version": "1.0.2",
  "main": "pixi.min.js",
  "scripts": {
    "sync": "npx cap sync",
    "open:ios": "bash tools/build-native.sh ios",
    "open:android": "bash tools/build-native.sh android",
    "build": "bash tools/build-native.sh",
    "build:aab": "cd android && ./gradlew bundleRelease && echo 'AAB: android/app/build/outputs/bundle/release/app-release.aab'",
    "test": "playwright test",
    "test:cardback:selection": "playwright test tests/cardback-selection.spec.js",
    "test:cardback:unlock": "playwright test tests/cardback-unlock.spec.js",
    "test:pwa:update": "playwright test tests/pwa-update.spec.js",
    "test:cardback:manifest": "node tools/check-cardback-manifest.mjs",
    "test:cardback:png": "python3 tools/check-cardback-png.py",
    "test:hardening": "npm run test:cardback:selection && npm run test:cardback:unlock && npm run test:pwa:update && npm run test:cardback:manifest && npm run test:cardback:png",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wulalainlondon/lucky3.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/wulalainlondon/lucky3/issues"
  },
  "homepage": "https://github.com/wulalainlondon/lucky3#readme",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "serve": "^14.2.6"
  },
  "dependencies": {
    "@capacitor-community/in-app-review": "^8.0.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2"
  }
}
